datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  CARE_COORDINATOR
  CAREGIVER
  FAMILY_MEMBER
}

enum ShiftStatus {
  UNCONFIRMED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  DROPPED
  NO_SHOW
}

enum PodRole {
  PRIMARY
  SECONDARY_1
  SECONDARY_2
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String
  name            String
  role            UserRole
  phoneNumber     String?
  createdAt       DateTime      @default(now())
  profileMetadata String?       // JSON-serialized string of additional intake/job details

  // Caregiver's home base location, used for proximity-based shift scheduling
  latitude        Float?
  longitude       Float?

  // Caregiver's hourly pay rate (USD), admin-set only, used for payroll reporting
  payRate         Float?

  // Relations
  podAssignments CaregiverPod[]
  assignedShifts Shift[]
  familyClients  LinkedFamilyMember[]
  auditLogs      AuditLog[]
  availabilities Availability[]
  shiftOffers    ShiftOffer[]
  notifications  Notification[]
  messages       Message[]
}

model Client {
  id                  String        @id @default(uuid())
  name                String
  address             String
  latitude            Float
  longitude           Float
  geofenceRadiusMeter Int           @default(150) // Default 150m radius
  createdAt           DateTime      @default(now())
  profileMetadata     String?       // JSON-serialized string of additional patient details

  // Relations
  caregiverPods  CaregiverPod[]
  shifts         Shift[]
  carePlans      CarePlan[]
  familyMembers  LinkedFamilyMember[]
  activityLogs   ActivityLog[]
  messages       Message[]
}

model CaregiverPod {
  id          String   @id @default(uuid())
  clientId    String
  caregiverId String
  role        PodRole
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caregiver   User     @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([clientId, caregiverId])
  @@unique([clientId, role]) // Ensure only one caregiver per role in the pod
}

model Shift {
  id                   String        @id @default(uuid())
  clientId             String
  caregiverId          String
  status               ShiftStatus   @default(UNCONFIRMED)
  scheduledStart       DateTime
  scheduledEnd         DateTime
  actualStart          DateTime?
  actualEnd            DateTime?
  
  // Confirmation Tracking
  confirmationDeadline DateTime
  confirmedAt          DateTime?

  // Geofencing & Exceptions
  clockInLat           Float?
  clockInLng           Float?
  clockOutLat          Float?
  clockOutLng          Float?
  isOverrideException  Boolean       @default(false)
  overrideReason       String?
  overrideApprovedBy   String?       // Reference to Admin User ID

  // Overtime Justification
  isOvertime           Boolean       @default(false)
  overtimeReason       String?
  overtimeEvidenceUrl  String?       // Signed URL / storage path for attached evidence

  // Relations
  client      Client                     @relation(fields: [clientId], references: [id])
  caregiver   User                       @relation(fields: [caregiverId], references: [id])
  locations   CaregiverLocationHistory[]
  tasks       ShiftTask[]
  activityLogs ActivityLog[]
  shiftOffers ShiftOffer[]
}

model CaregiverLocationHistory {
  id        String   @id @default(uuid())
  shiftId   String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())

  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model CarePlan {
  id        String   @id @default(uuid())
  clientId  String
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks     CarePlanTask[]
}

model CarePlanTask {
  id            String   @id @default(uuid())
  carePlanId    String
  taskName      String   // e.g. "Medication reminder"
  description   String   // e.g. "Take 2 tabs of Lisinopril"
  scheduledTime String   // e.g. "08:00 AM" or shift-offset
  isMandatory   Boolean  @default(true)

  carePlan      CarePlan @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
}

model ShiftTask {
  id            String    @id @default(uuid())
  shiftId       String
  taskName      String
  description   String
  scheduledTime String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?

  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model LinkedFamilyMember {
  id       String @id @default(uuid())
  clientId String
  userId   String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
}

model ActivityLog {
  id          String   @id @default(uuid())
  clientId    String
  shiftId     String?
  encryptedLog String   // AES-256 encrypted log details
  mediaUrls   String   // JSON-serialized string of signed URLs or Storage paths
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  shift       Shift?   @relation(fields: [shiftId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g. "VIEW_PATIENT_RECORD", "DELETE_SHIFT"
  details   String   // Details of data targeted
  timestamp DateTime @default(now())
  outcome   String   // "SUCCESS" or "FAILURE"

  user      User     @relation(fields: [userId], references: [id])
}

model Availability {
  id          String   @id @default(uuid())
  caregiverId String
  dayOfWeek   Int      // 0 = Sunday, 1 = Monday, etc.
  startTime   String   // e.g. "08:00"
  endTime     String   // e.g. "17:00"

  caregiver   User     @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
}

model ShiftOffer {
  id          String      @id @default(uuid())
  shiftId     String
  caregiverId String
  status      String      @default("PENDING") // PENDING, ACCEPTED, DECLINED
  expiresAt   DateTime

  shift       Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  caregiver   User        @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String
  purpose   String   // "SIGNUP" or "PASSWORD_RESET"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token, purpose])
}

model Message {
  id            String   @id @default(uuid())
  clientId      String   // conversation is scoped to a client - all pod caregivers + linked family share one thread
  senderId      String
  encryptedText String?  // AES-256-GCM encrypted text content; null for media-only messages
  mediaUrl      String?  // signed URL for a photo/video/audio attachment
  mediaType     String?  // 'image' | 'video' | 'audio'
  mediaName     String?
  createdAt     DateTime @default(now())

  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sender        User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

